# ─── Supabase ───────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — NEVER expose to the client, server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Resend (transactional email) ──────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
# Must be a verified domain in Resend
RESEND_FROM_EMAIL=noreply@straight2guide.com
RESEND_ADMIN_EMAIL=admin@straight2guide.com

# ─── PostHog (analytics) ────────────────────────────────────────────────────
# https://posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
# Use EU host if your users are primarily European
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Sentry (error monitoring) ──────────────────────────────────────────────
# https://sentry.io → Project → Settings → SDK Setup
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=straight2guide

# ─── App ────────────────────────────────────────────────────────────────────
# Full URL of the deployment (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
